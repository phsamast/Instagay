rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isParticipant() {
      return signedIn() && request.auth.uid in resource.data.participants;
    }

    function willBeParticipant() {
      return signedIn() && request.auth.uid in request.resource.data.participants;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (signedIn() && changedOnly(['followers']));
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if signedIn();
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        changedOnly(['likes'])
      );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if signedIn() && resource.data.userId == request.auth.uid;
        allow delete: if signedIn() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/posts/$(postId)).data.ownerId == request.auth.uid
        );
      }
    }

    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        changedOnly(['viewers'])
      );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isParticipant();
      allow create: if willBeParticipant();
      allow update: if isParticipant() && willBeParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && (
            !exists(/databases/$(database)/documents/chats/$(chatId)) ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          );

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && changedOnly(['isRead']);

        allow delete: if false;
      }
    }

    match /hashtags/{tagId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }
  }
}